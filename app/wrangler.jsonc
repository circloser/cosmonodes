{
  // Cloudflare Workers static-assets config for the built Vite SPA.
  // Build first (npm run build) so ./dist exists, then `wrangler deploy`
  // uploads ./dist and serves index.html with SPA fallback.
  "name": "cosmonodes",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
